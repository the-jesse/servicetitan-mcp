# ServiceTitan MCP Configuration
# Copy to .env and fill with your values

# ServiceTitan Credentials (get from developer portal)
ST_CLIENT_ID=your_client_id
ST_CLIENT_SECRET=your_client_secret
ST_APP_KEY=your_app_key
ST_TENANT_ID=your_tenant_id   # Optional if using dynamic or multi-tenant

# Environment: sandbox or production
ST_ENV=sandbox

# Optional: Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Future: Webhook secret or other configs
